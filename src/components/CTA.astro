<section class="py-24 bg-light-bg relative">
    <!-- Decorative background element -->
    <div
        class="absolute top-0 right-0 w-1/3 h-full bg-accent-green/5 rounded-l-[100px] pointer-events-none"
    >
    </div>

    <div class="container mx-auto px-6 relative z-10">
        <div
            class="bg-primary-dark rounded-[40px] p-12 md:p-20 overflow-hidden relative shadow-2xl"
        >
            <!-- Background Abstract Shape -->
            <div
                class="absolute top-0 right-0 w-[400px] h-[400px] bg-accent-green rounded-full blur-[100px] opacity-20 transform translate-x-1/2 -translate-y-1/2"
            >
            </div>

            <div
                class="flex flex-col md:flex-row items-center justify-between gap-12"
            >
                <div class="md:w-1/2">
                    <h2 class="text-4xl md:text-5xl text-white font-light mb-6">
                        Suscríbete para <br /><strong
                            class="text-accent-green font-bold"
                            >Novedades Sonoras</strong
                        >
                    </h2>
                    <p class="text-gray-300 text-lg mb-8 max-w-md">
                        Recibe actualizaciones mensuales sobre nuevas especies
                        catalogadas y reportes de salud de los ecosistemas.
                    </p>

                    <form class="flex flex-col sm:flex-row gap-4">
                        <input
                            type="email"
                            placeholder="Tu correo electrónico"
                            class="px-6 py-4 rounded-full bg-white/10 border border-white/20 text-white placeholder-gray-400 focus:outline-none focus:border-accent-green focus:bg-white/20 transition-all flex-grow"
                        />
                        <button
                            class="px-8 py-4 rounded-full bg-accent-green text-primary-dark font-bold hover:bg-white transition-colors"
                        >
                            Suscribirse
                        </button>
                    </form>
                </div>

                <div class="md:w-1/3 relative">
                    <!-- Abstract Card Representation -->
                    <div
                        class="bg-white/10 backdrop-blur-md p-8 rounded-2xl border border-white/10 transform rotate-3 hover:rotate-0 transition-transform duration-500"
                    >
                        <div class="flex items-center gap-4 mb-6">
                            <div
                                class="w-12 h-12 bg-accent-green rounded-full flex items-center justify-center text-primary-dark"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke-width="2"
                                    stroke="currentColor"
                                    class="w-6 h-6"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z"
                                    ></path>
                                </svg>
                            </div>
                            <div>
                                <div class="h-2 w-24 bg-white/50 rounded mb-2">
                                </div>
                                <div class="h-2 w-16 bg-white/30 rounded"></div>
                            </div>
                        </div>
                        <div class="h-2 w-full bg-white/10 rounded mb-3"></div>
                        <div class="h-2 w-full bg-white/10 rounded mb-3"></div>
                        <div class="h-2 w-3/4 bg-white/10 rounded"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
