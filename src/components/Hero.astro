<section
    class="relative h-screen min-h-[600px] flex items-center justify-center overflow-hidden"
>
    <!-- Background Image -->
    <div class="absolute inset-0 z-0">
        <img
            src="https://images.unsplash.com/photo-1441974231531-c6227db76b6e?q=80&w=2560&auto=format&fit=crop"
            alt="Forest Background"
            class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-primary-dark/60 mix-blend-multiply">
        </div>
    </div>

    <!-- Content -->
    <div class="relative z-10 container mx-auto px-6 text-left">
        <div class="max-w-4xl">
            <h1
                id="hero-title"
                class="text-5xl md:text-6xl lg:text-8xl font-light text-white mb-6 tracking-wide opacity-0 animate-fade-up transition-all duration-500 min-h-[1.2em] text-accent-green"
                style="animation-delay: 0.2s; animation-fill-mode: forwards;"
            >
                Conoce la belleza de la naturaleza
            </h1>

            <p
                class="text-lg text-gray-200 mb-10 max-w-2xl font-light opacity-0 animate-fade-up pl-1"
                style="animation-delay: 0.4s; animation-fill-mode: forwards;"
            >
                Una colección sonora que conecta con la biodiversidad del mundo.
                Descubre la belleza de la naturaleza a través de nuestras
                grabaciones.
            </p>

            <a
                href="#species"
                class="inline-block bg-white -dark font-semibold py-4 px-10 rounded-full hover:bg-gray-100 hover:scale-105 transition-all duration-300 opacity-0 animate-fade-up shadow-lg text-accent-green uppercase"
                style="animation-delay: 0.6s; animation-fill-mode: forwards;"
            >
                Escuchar Ahora
            </a>
        </div>
    </div>

    <!-- Scroll Indicator -->
    <div
        class="absolute bottom-10 left-1/2 transform -translate-x-1/2 animate-bounce text-white/50"
    >
        <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="w-6 h-6"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
        </svg>
    </div>
</section>

<script>
    const titles = [
        "<span class='text-accent-green dark:text-white'>Sonidos del Bosque</span ",
        "<span class='text-accent-green dark:text-white'>Susurros de la Vida</span ",
    ];

    const titleElement = document.getElementById("hero-title");
    let currentIndex = 0;

    if (titleElement) {
        setInterval(() => {
            // Fade out
            titleElement.style.opacity = "0";
            titleElement.style.transform = "translateY(20px)";

            setTimeout(() => {
                // Change text
                currentIndex = (currentIndex + 1) % titles.length;
                titleElement.innerHTML = titles[currentIndex];

                // Fade in
                titleElement.style.opacity = "1";
                titleElement.style.transform = "translateY(0)";
            }, 500); // Wait for fade out
        }, 4000); // Change every 4 seconds
    }
</script>

<style>
    @keyframes fade-up {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-up {
        animation-name: fade-up;
        animation-duration: 1s;
        animation-timing-function: ease-out;
    }
</style>
