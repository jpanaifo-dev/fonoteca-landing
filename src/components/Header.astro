---
import logoIiap from "../assets/logo_iiap.png";
---

<header
    class="fixed top-0 left-0 w-full z-50 transition-all duration-300 bg-transparent py-6"
    id="main-header"
>
    <div
        class="container mx-auto px-6 flex justify-between items-center h-full"
    >
        <a
            href="#"
            id="logo-link"
            class="group text-white flex gap-3 items-center transition-colors duration-300"
        >
            <img
                src={logoIiap.src}
                alt="Logo IIAP"
                class="h-12 w-auto object-contain transition-transform group-hover:scale-105"
            />
            <span
                class="text-sm md:text-base font-medium max-w-[260px] leading-tight"
            >
                Instituto de Investigaciones de la Amazonía Peruana
            </span>
        </a>

        <button
            id="menu-btn"
            class="group flex flex-col gap-1.5 w-8 cursor-pointer z-50"
        >
            <span
                class="block w-full h-0.5 bg-white transition-all group-hover:bg-accent-green"
            ></span>
            <span
                class="block w-3/4 h-0.5 bg-white ml-auto transition-all group-hover:bg-accent-green group-hover:w-full"
            ></span>
            <span
                class="block w-full h-0.5 bg-white transition-all group-hover:bg-accent-green"
            ></span>
        </button>
    </div>
</header>

<!-- Overlay Menu -->
<div
    id="menu-overlay"
    class="fixed inset-0 z-40 translate-x-full transition-transform duration-500 ease-in-out"
>
    <!-- Backdrop -->
    <div
        class="absolute inset-0 bg-primary-dark/90 backdrop-blur-sm"
        id="menu-backdrop"
    >
    </div>

    <!-- Menu Content -->
    <div
        class="absolute right-0 top-0 h-full w-full md:w-1/2 lg:w-1/3 bg-white text-primary-dark shadow-2xl transform transition-transform duration-500 delay-100 translate-x-full"
        id="menu-panel"
    >
        <!-- Curved Shape (The Organic Edge) -->
        <div
            class="absolute top-0 left-0 w-24 h-full -translate-x-1/2 overflow-hidden pointer-events-none hidden md:block"
        >
            <div
                class="w-[200%] h-full bg-white rounded-l-[100%] absolute right-0"
            >
            </div>
        </div>

        <div class="relative z-10 h-full flex flex-col p-12 justify-center">
            <button
                id="close-menu"
                class="absolute top-8 right-8 text-primary-dark hover:text-accent-green transition-colors"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke="currentColor"
                    class="w-8 h-8"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>

            <nav class="space-y-6 text-3xl font-light">
                <a
                    href="#"
                    class="block hover:text-accent-green hover:translate-x-2 transition-all"
                    >Inicio</a
                >
                <a
                    href="#"
                    class="block hover:text-accent-green hover:translate-x-2 transition-all"
                    >La Fonoteca</a
                >
                <a
                    href="#"
                    class="block hover:text-accent-green hover:translate-x-2 transition-all"
                    >Especies</a
                >
                <a
                    href="#"
                    class="block hover:text-accent-green hover:translate-x-2 transition-all"
                    >Estadísticas</a
                >
                <a
                    href="#"
                    class="block hover:text-accent-green hover:translate-x-2 transition-all"
                    >Contacto</a
                >
            </nav>

            <div class="mt-12 pt-12 border-t border-gray-100">
                <p class="text-sm text-gray-500">
                    © 2025 Voces de la Naturaleza
                </p>
            </div>
        </div>
    </div>
</div>

<script>
    const menuBtn = document.getElementById("menu-btn");
    const closeMenu = document.getElementById("close-menu");
    const menuOverlay = document.getElementById("menu-overlay");
    const menuPanel = document.getElementById("menu-panel");
    const menuBackdrop = document.getElementById("menu-backdrop");

    // Navbar Scroll Effect
    const header = document.getElementById("main-header");
    const logoLink = document.getElementById("logo-link");
    const menuSpans = document.querySelectorAll("#menu-btn span");

    function handleScroll() {
        if (window.scrollY > 50) {
            header?.classList.remove("bg-transparent");
            header?.classList.add("bg-white", "shadow-sm", "py-4");
            header?.classList.remove("py-6"); // Reduce padding slightly on scroll

            logoLink?.classList.remove("text-white");
            logoLink?.classList.add("text-primary-dark");

            menuSpans.forEach((span) => {
                span.classList.remove("bg-white");
                span.classList.add("bg-primary-dark");
            });
        } else {
            header?.classList.add("bg-transparent");
            header?.classList.remove("bg-white", "shadow-sm", "py-4");
            header?.classList.add("py-6"); // Restore original padding

            logoLink?.classList.add("text-white");
            logoLink?.classList.remove("text-primary-dark");

            menuSpans.forEach((span) => {
                span.classList.add("bg-white");
                span.classList.remove("bg-primary-dark");
            });
        }
    }

    window.addEventListener("scroll", handleScroll);

    function toggleMenu() {
        const isClosed = menuOverlay?.classList.contains("translate-x-full");

        if (isClosed) {
            menuOverlay?.classList.remove("translate-x-full");
            // Staggered animation
            requestAnimationFrame(() => {
                menuPanel?.classList.remove("translate-x-full");
            });
            document.body.style.overflow = "hidden";
        } else {
            menuPanel?.classList.add("translate-x-full");
            setTimeout(() => {
                menuOverlay?.classList.add("translate-x-full");
                document.body.style.overflow = "";
            }, 300); // Wait for panel to slide out
        }
    }

    menuBtn?.addEventListener("click", toggleMenu);
    closeMenu?.addEventListener("click", toggleMenu);
    menuBackdrop?.addEventListener("click", toggleMenu);
</script>
