---
import Layout from "../../layouts/Layout.astro";
import { Header } from "../../components/react/Header";
import { Footer } from "../../components/react/Footer";
import { PageBanner } from "../../components/react/PageBanner";
import { translations, LANGUAGES } from "../../i18n/data";
import logoIiap from "../../assets/logo_iiap.png";
import { landingImages } from "../../config/landingImages";

export function getStaticPaths() {
    return LANGUAGES.map((lang) => ({
        params: { lang },
    }));
}

const { lang } = Astro.params;
const content = translations[lang as keyof typeof translations];
---

<Layout
    title={`${content.nav.stats} - ${content.nav.library}`}
    lang={lang}
    description="Estadísticas de la Biblioteca Acústica"
>
    <Header
        client:load
        content={content.nav}
        logoSrc={logoIiap.src}
        lang={lang}
    />
    <main>
        <PageBanner
            title={content.nav.stats}
            subtitle="Datos de nuestra colección"
            image={landingImages.pageBanner.default}
        />
        <section class="py-24 bg-light-bg">
            <div class="container mx-auto px-6">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    {/* Placeholder Stats */}
                    <div class="bg-white p-8 rounded-3xl shadow-sm text-center">
                        <h3 class="text-4xl font-bold text-accent-green mb-2">
                            1,240
                        </h3>
                        <p class="text-gray-600">Archivos de Audio</p>
                    </div>
                    <div class="bg-white p-8 rounded-3xl shadow-sm text-center">
                        <h3 class="text-4xl font-bold text-accent-green mb-2">
                            320
                        </h3>
                        <p class="text-gray-600">Especies Registradas</p>
                    </div>
                    <div class="bg-white p-8 rounded-3xl shadow-sm text-center">
                        <h3 class="text-4xl font-bold text-accent-green mb-2">
                            15
                        </h3>
                        <p class="text-gray-600">Proyectos Activos</p>
                    </div>
                </div>
            </div>
        </section>
    </main>
    <Footer content={content.footer} logoSrc={logoIiap.src} />
</Layout>
