---
import Layout from "../../layouts/Layout.astro";
import { Header } from "../../components/react/Header";
import { Footer } from "../../components/react/Footer";
import { AudioList } from "../../components/react/AudioList";
import { getAllSpecies } from "../../data/species";
import { translations, LANGUAGES } from "../../i18n/data";
import logoIiap from "../../assets/logo_iiap.png";

export function getStaticPaths() {
    return LANGUAGES.map((lang) => ({
        params: { lang },
    }));
}

const { lang } = Astro.params;
const content = translations[lang as keyof typeof translations];
const allSpecies = getAllSpecies();
---

<Layout
    title="Fonoteca - Instituto de Investigaciones de la Amazonía Peruana"
    lang={lang}
>
    <Header
        client:load
        content={content.nav}
        logoSrc={logoIiap.src}
        lang={lang}
    />
    <main>
        <div class="pt-24 pb-8 bg-primary-dark text-white">
            <div class="container mx-auto px-6">
                <h1 class="text-4xl md:text-5xl font-light mb-4">
                    {content.nav.library}
                </h1>
                <p class="text-lg text-gray-300 max-w-2xl">
                    {content.hero.description}
                </p>
            </div>
        </div>

        <section class="py-12 bg-light-bg min-h-screen">
            <div class="container mx-auto px-6">
                <AudioList client:load allSpecies={allSpecies} lang={lang} />
            </div>
        </section>
    </main>
    <Footer content={content.footer} logoSrc={logoIiap.src} />
</Layout>
