---
import Layout from "../../layouts/Layout.astro";
import { Header } from "../../components/react/Header";
import { Footer } from "../../components/react/Footer";
import { Hero } from "../../components/react/Hero";
import { Intro } from "../../components/react/Intro";
import { FeatureGrid } from "../../components/react/FeatureGrid";
import { ServicesGrid } from "../../components/react/ServicesGrid";
import { Stats } from "../../components/react/Stats";
import { StatsChart } from "../../components/react/StatsChart";
import { CTA } from "../../components/react/CTA";
import { AudioList } from "../../components/react/AudioList";
import { getAllSpecies } from "../../data/species";
import { translations, LANGUAGES } from "../../i18n/data";
import logoIiap from "../../assets/logo_iiap.png";

export function getStaticPaths() {
    return LANGUAGES.map((lang) => ({
        params: { lang },
    }));
}

const { lang } = Astro.params;
const content = translations[lang as keyof typeof translations];
const allSpecies = await getAllSpecies();
---

<Layout
    title="Fonoteca - Instituto de Investigaciones de la Amazonía Peruana"
    lang={lang}
>
    <Header
        client:load
        content={content.nav}
        logoSrc={logoIiap.src}
        lang={lang}
    />
    <main>
        <Hero client:load content={content.hero} lang={lang as string} />
        <Intro content={content.intro} />

        {/* Audio Archive Section */}
        <section
            id="library"
            class="py-12 bg-white dark:bg-[#0c141d] scroll-mt-20"
        >
            <div class="w-full max-w-[1400px] mx-auto px-6">
                <div class="mb-12 text-center">
                    <h2
                        class="text-3xl md:text-4xl font-light text-primary-dark dark:text-white mb-4"
                    >
                        {content.nav.library}
                    </h2>
                    <p
                        class="text-gray-600 dark:text-gray-300 max-w-2xl mx-auto"
                    >
                        Explora nuestra colección completa de grabaciones de
                        alta fidelidad.
                    </p>
                </div>
                <AudioList client:load allSpecies={allSpecies.slice(0, 4)} lang={lang} />
                <div class="mt-8 text-center">
                    <a href={`/${lang}/species`} class="inline-flex items-center gap-2 border border-gray-200 dark:border-gray-700 hover:border-accent-green bg-white dark:bg-[#121b28] text-primary-dark dark:text-white font-medium py-3 px-8 rounded-full transition-all shadow-sm hover:shadow-md">
                        Ver Más Grabaciones &rarr;
                    </a>
                </div>
            </div>
        </section>

        <section class="py-12 bg-gray-50 dark:bg-gray-900">
            <StatsChart client:visible />
        </section>

        <Stats content={content.stats} />
        <FeatureGrid client:visible data={content.features} />
        <ServicesGrid content={content.species} />
        <CTA content={content.cta} />
    </main>
    <Footer content={content.footer} logoSrc={logoIiap.src} />
</Layout>
