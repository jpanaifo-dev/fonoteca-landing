---
import Layout from "../../layouts/Layout.astro";
import { Header } from "../../components/react/Header";
import { Footer } from "../../components/react/Footer";
import { Hero } from "../../components/react/Hero";
import { Intro } from "../../components/react/Intro";
import { FeatureGrid } from "../../components/react/FeatureGrid";
import { ServicesGrid } from "../../components/react/ServicesGrid";
import { Stats } from "../../components/react/Stats";
import { StatsChart } from "../../components/react/StatsChart";
import { CTA } from "../../components/react/CTA";
import { PlaylistCarousel } from "../../components/react/PlaylistCarousel";
import { getAllSpecies } from "../../data/species";
import { translations, LANGUAGES } from "../../i18n/data";
import logoIiap from "../../assets/logo_iiap.png";

export function getStaticPaths() {
    return LANGUAGES.map((lang) => ({
        params: { lang },
    }));
}

const { lang } = Astro.params;
const content = translations[lang as keyof typeof translations];
const allSpecies = await getAllSpecies();
---

<Layout
    title="Fonoteca - Instituto de Investigaciones de la Amazonía Peruana"
    lang={lang}
>
    <Header
        client:load
        content={content.nav}
        logoSrc={logoIiap.src}
        lang={lang}
    />
    <main>
        <Hero client:load content={content.hero} lang={lang as string} />
        {/* Audio Archive Section */}
        <section
            id="library"
            class="py-20 bg-white dark:bg-[#0c141d] scroll-mt-20"
        >
            <div class="w-full container mx-auto px-6 mb-12">
                <PlaylistCarousel
                    client:load
                    allSpecies={allSpecies}
                    lang={lang as "es" | "en" | "pt"}
                    title={content.nav.library}
                />
            </div>
        </section>

        <StatsChart client:visible />

        <Stats content={content.stats} />
        <FeatureGrid client:visible data={content.features} />
        <ServicesGrid content={content.species} />
        <CTA content={content.cta} />
    </main>
    <Footer content={content.footer} logoSrc={logoIiap.src} />
</Layout>
