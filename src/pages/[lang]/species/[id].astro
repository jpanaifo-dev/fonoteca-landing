---
import Layout from "../../../layouts/Layout.astro";
import { Header } from "../../../components/react/Header";
import { Footer } from "../../../components/react/Footer";
import { PageBanner } from "../../../components/react/PageBanner";
import { SpeciesGallery } from "../../../components/react/SpeciesGallery";
import { AudioPlayer } from "../../../components/react/AudioPlayer";
import { translations, LANGUAGES, type Language } from "../../../i18n/data";
import {
    getAllSpecies,
    getSpeciesById,
    type Species,
} from "../../../data/species";
import logoIiap from "../../../assets/logo_iiap.png";

export async function getStaticPaths() {
    const { species } = await getAllSpecies({ limit: 1000 });

    return LANGUAGES.flatMap((lang) =>
        species.map((s: Species) => ({
            params: { lang, id: s.id },
        })),
    );
}

const { lang, id } = Astro.params;

// Siempre buscar los detalles completos del registro (incluida la ficha técnica)
// que getAllSpecies no necesariamente incluye en la vista de lista.
const species = await getSpeciesById(id!);
const content = translations[lang as keyof typeof translations];
const currentLang = lang as Language;

if (!species) {
    return Astro.redirect(`/${lang}/species`);
}

// Localized data
const commonName = species[
    `commonName_${currentLang}` as keyof Species
] as string;
const description =
    species.description[currentLang as keyof typeof species.description];
const characteristics = species.characteristics
    ? species.characteristics[
          currentLang as keyof typeof species.characteristics
      ]
    : undefined;

// Breadcrumbs implementation
const breadcrumbs = {
    backLink: `/${lang}/species`,
    backText:
        lang === "es"
            ? "Volver a la lista"
            : lang === "pt"
              ? "Voltar para lista"
              : "Back to list",
    currentText:
        lang === "es" ? "Detalles" : lang === "pt" ? "Detalhes" : "Details",
};

// Taxonomy chain string for body
// Attempt to use kingdom and phylum if they exist on the object, otherwise rely on the available taxonomy down to genus.
const taxonomyParts = [
    (species as any).kingdom || "Animalia",
    (species as any).phylum,
    species.class_name,
    species.order,
    species.family,
    species.genus,
].filter(Boolean);
const taxonomy =
    taxonomyParts.length > 0 ? taxonomyParts.join(" - ") : undefined;
---

<Layout
    title={`${commonName} - ${content.nav.library}`}
    lang={lang}
    description={`Escucha el sonido de: ${commonName} (${species.scientificName})`}
    image={species.mainImage}
>
    <Header
        client:load
        content={content.nav}
        logoSrc={logoIiap.src}
        lang={lang}
    />
    <main>
        <PageBanner
            title={commonName}
            subtitle={species.scientificName}
            image={species.mainImage}
            breadcrumbs={breadcrumbs}
        />

        <section class="py-24 bg-white">
            <div class="container mx-auto px-6">
                {/* Back Link Removed: Now in PageBanner */}

                <div class="max-w-5xl mx-auto">
                    {/* Header Section: Titles & Location */}
                    <div class="text-center mb-12">
                        {
                            taxonomy && (
                                <div class="mb-4 text-accent-green font-bold text-xs md:text-sm uppercase tracking-widest animate-fade-in">
                                    {taxonomy}
                                </div>
                            )
                        }
                        <h1
                            class="text-4xl md:text-6xl text-primary-dark font-light mb-4"
                        >
                            {commonName}
                        </h1>
                        <h2
                            class="text-2xl md:text-3xl text-accent-green font-serif italic mb-6"
                        >
                            {species.scientificName}
                        </h2>

                        <div
                            class="inline-flex items-center gap-3 text-gray-500 bg-gray-50 px-6 py-3 rounded-full border border-gray-100"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                class="w-5 h-5 text-accent-green"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"
                                ></path>
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
                                ></path>
                            </svg>
                            <span class="font-medium">{species.location}</span>
                        </div>
                    </div>

                    {/* Gallery Section - Centered */}
                    {
                        species.galleryImages &&
                            species.galleryImages.length > 0 && (
                                <div class="mb-16">
                                    <SpeciesGallery
                                        client:load
                                        images={species.galleryImages.map(
                                            (img) => img.url,
                                        )}
                                    />
                                </div>
                            )
                    }
                </div>

                <div class="mb-16 w-full max-w-5xl mx-auto">
                    <h3
                        class="text-3xl font-bold text-primary-dark dark:text-white mb-8 text-center"
                    >
                        {
                            lang === "es"
                                ? "Análisis Acústico (Audios y Visualización)"
                                : lang === "pt"
                                  ? "Análise Acústica"
                                  : "Acoustic Analysis"
                        }
                    </h3>
                    <div class="space-y-12">
                        {
                            species.audios.map((audio) => (
                                <div class="w-full">
                                    <AudioPlayer
                                        client:only="react"
                                        audioUrl={audio.url}
                                        title={audio.title ?? undefined}
                                        artist={commonName}
                                        description={
                                            audio.description ?? undefined
                                        }
                                        spectrogramImage={
                                            audio.spectrogramImage ?? undefined
                                        }
                                    />
                                </div>
                            ))
                        }
                    </div>
                </div>

                {/* Spectrograms Gallery Section */}
                {
                    species.spectrograms && species.spectrograms.length > 0 && (
                        <div class="mb-16 w-full max-w-5xl mx-auto border-t border-gray-100 dark:border-gray-800 pt-16">
                            <h3 class="text-3xl font-bold text-primary-dark dark:text-white mb-8 text-center">
                                {lang === "es"
                                    ? "Galería de Espectrogramas / Histogramas"
                                    : lang === "pt"
                                      ? "Galeria de Espectrogramas"
                                      : "Spectrograms Gallery"}
                            </h3>
                            <div class="bg-gray-50 dark:bg-gray-900/50 p-6 rounded-3xl">
                                <SpeciesGallery
                                    client:load
                                    images={species.spectrograms.map(
                                        (img) => img.url,
                                    )}
                                />
                            </div>
                        </div>
                    )
                }

                <div class="max-w-5xl mx-auto">
                    {/* Info & Characteristics Section */}
                    <div
                        class="grid grid-cols-1 gap-8 border-t border-gray-100 dark:border-gray-800 pt-12"
                    >
                        {/* Descriptive Info */}
                        <div class="md:col-span-2 space-y-8">
                            <div
                                class="prose prose-lg dark:prose-invert text-gray-600 dark:text-gray-300"
                            >
                                <h3
                                    class="text-2xl font-bold text-primary-dark dark:text-white mb-4"
                                >
                                    {
                                        lang === "es"
                                            ? "Descripción"
                                            : lang === "pt"
                                              ? "Descrição"
                                              : "Description"
                                    }
                                </h3>
                                <p>{description}</p>
                            </div>
                            <hr class="border-gray-100 dark:border-gray-800" />
                            {/* Database Ficha Card */}
                            {
                                species.databaseDetails && (
                                    <div class="bg-white dark:bg-[#121b28]">
                                        <h3 class="text-xl font-bold text-primary-dark dark:text-white mb-6">
                                            {lang === "es"
                                                ? "Detalles del Registro"
                                                : lang === "pt"
                                                  ? "Detalhes do Registro"
                                                  : "Record Details"}
                                        </h3>

                                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                                            {/* Taxonomía */}
                                            <div class="space-y-4">
                                                <h4 class="text-sm font-bold tracking-widest text-gray-400 uppercase">
                                                    {lang === "es"
                                                        ? "Taxonomía"
                                                        : "Taxonomy"}
                                                </h4>
                                                <dl class="space-y-2 text-sm">
                                                    {[
                                                        {
                                                            label: "Clase",
                                                            value: species.class_name,
                                                        },
                                                        {
                                                            label: "Orden",
                                                            value: species.order,
                                                        },
                                                        {
                                                            label: "Familia",
                                                            value: species.family,
                                                        },
                                                        {
                                                            label: "Género",
                                                            value: species.genus,
                                                        },
                                                    ].map(
                                                        (item) =>
                                                            item.value && (
                                                                <div class="flex justify-between border-b border-gray-50 dark:border-gray-800 pb-1">
                                                                    <dt class="text-gray-500 dark:text-gray-400">
                                                                        {
                                                                            item.label
                                                                        }
                                                                    </dt>
                                                                    <dd class="font-medium text-gray-900 dark:text-white italic">
                                                                        {
                                                                            item.value
                                                                        }
                                                                    </dd>
                                                                </div>
                                                            ),
                                                    )}
                                                </dl>
                                            </div>

                                            {/* Evento y Localidad */}
                                            <div class="space-y-4">
                                                <h4 class="text-sm font-bold tracking-widest text-gray-400 uppercase">
                                                    {lang === "es"
                                                        ? "Evento y Localidad"
                                                        : "Event & Location"}
                                                </h4>
                                                <dl class="space-y-2 text-sm">
                                                    {[
                                                        {
                                                            label:
                                                                lang === "es"
                                                                    ? "Fecha"
                                                                    : "Date",
                                                            value: species
                                                                .databaseDetails
                                                                ?.eventDate,
                                                        },
                                                        {
                                                            label:
                                                                lang === "es"
                                                                    ? "País"
                                                                    : "Country",
                                                            value: species
                                                                .databaseDetails
                                                                ?.country,
                                                        },
                                                        {
                                                            label:
                                                                lang === "es"
                                                                    ? "Estado/Provincia"
                                                                    : "State/Province",
                                                            value: species
                                                                .databaseDetails
                                                                ?.stateProvince,
                                                        },
                                                        {
                                                            label:
                                                                lang === "es"
                                                                    ? "Localidad"
                                                                    : "Locality",
                                                            value: species
                                                                .databaseDetails
                                                                ?.locality,
                                                        },
                                                        {
                                                            label: "Elevación",
                                                            value: species
                                                                .databaseDetails
                                                                ?.elevation
                                                                ? `${species.databaseDetails.elevation}m`
                                                                : null,
                                                        },
                                                    ].map(
                                                        (item) =>
                                                            item.value && (
                                                                <div class="flex justify-between border-b border-gray-50 dark:border-gray-800 pb-1 gap-2">
                                                                    <dt class="text-gray-500 dark:text-gray-400 shrink-0">
                                                                        {
                                                                            item.label
                                                                        }
                                                                    </dt>
                                                                    <dd
                                                                        class="font-medium text-gray-900 dark:text-white truncate"
                                                                        title={item.value.toString()}
                                                                    >
                                                                        {
                                                                            item.value
                                                                        }
                                                                    </dd>
                                                                </div>
                                                            ),
                                                    )}
                                                </dl>
                                            </div>

                                            {/* Especimen */}
                                            <div class="space-y-4 sm:col-span-2 mt-2">
                                                <h4 class="text-sm font-bold tracking-widest text-gray-400 uppercase">
                                                    {lang === "es"
                                                        ? "Detalles del Especimen"
                                                        : "Specimen Details"}
                                                </h4>
                                                <dl class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm bg-gray-50 dark:bg-[#0c141d] p-4 rounded-xl">
                                                    {[
                                                        {
                                                            label: "Sex",
                                                            value: species
                                                                .databaseDetails
                                                                ?.sex,
                                                        },
                                                        {
                                                            label: "Life Stage",
                                                            value: species
                                                                .databaseDetails
                                                                ?.lifeStage,
                                                        },
                                                        {
                                                            label: "Institution",
                                                            value: species
                                                                .databaseDetails
                                                                ?.institutionCode,
                                                        },
                                                        {
                                                            label: "Catalog No.",
                                                            value: species
                                                                .databaseDetails
                                                                ?.catalogNumber,
                                                        },
                                                        {
                                                            label: "Identified By",
                                                            value: species
                                                                .databaseDetails
                                                                ?.identifiedBy,
                                                        },
                                                    ].map(
                                                        (item) =>
                                                            item.value && (
                                                                <div>
                                                                    <dt class="text-xs text-gray-500 dark:text-gray-400 uppercase">
                                                                        {
                                                                            item.label
                                                                        }
                                                                    </dt>
                                                                    <dd class="font-bold text-gray-900 dark:text-white mt-1">
                                                                        {
                                                                            item.value
                                                                        }
                                                                    </dd>
                                                                </div>
                                                            ),
                                                    )}
                                                </dl>
                                            </div>
                                        </div>
                                    </div>
                                )
                            }
                        </div>

                        {/* Sidebar / Actions */}
                        <div class="space-y-8">
                            {
                                characteristics &&
                                    characteristics.length > 0 && (
                                        <div class="bg-gray-50 dark:bg-[#121b28] p-6 rounded-2xl border border-gray-100 dark:border-gray-800">
                                            <h3 class="text-lg font-bold text-primary-dark dark:text-white mb-4">
                                                {lang === "es"
                                                    ? "Notas Adicionales"
                                                    : lang === "pt"
                                                      ? "Notas Adicionais"
                                                      : "Additional Notes"}
                                            </h3>
                                            <ul class="space-y-3 text-sm text-gray-600 dark:text-gray-300">
                                                {characteristics.map((char) => (
                                                    <li class="flex items-start gap-2">
                                                        <span class="text-accent-green mt-0.5">
                                                            •
                                                        </span>
                                                        {char}
                                                    </li>
                                                ))}
                                            </ul>
                                        </div>
                                    )
                            }

                            <div>
                                <button
                                    class="w-full px-6 py-4 rounded-xl border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:border-accent-green hover:text-accent-green transition-all font-bold flex items-center justify-center gap-2 bg-white dark:bg-[#121b28] shadow-sm hover:shadow-md"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke-width="2"
                                        stroke="currentColor"
                                        class="w-5 h-5"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.935 2.186 2.25 2.25 0 00-3.935-2.186zm0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185z"
                                        ></path>
                                    </svg>
                                    {
                                        lang === "es"
                                            ? "Compartir"
                                            : lang === "pt"
                                              ? "Compartilhar"
                                              : "Share"
                                    }
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
    <Footer content={content.footer} logoSrc={logoIiap.src} />

    <script define:vars={{ species, commonName }}>
        // Initialize PersistentPlayer with this species' audios
        function initPlaylist() {
            if (species.audios && species.audios.length > 0) {
                const playlist = species.audios.map((audio) => ({
                    title: audio.title || "Canto",
                    artist: commonName,
                    url: audio.url,
                    image: species.mainImage || "/images/logo-mini.webp", // Using main image as fallback, but spectrogram is primary for thumbnail
                    spectrogram: audio.spectrogramImage ?? undefined,
                }));

                const playlistData = {
                    playlist: playlist,
                    startAtIndex: 0,
                    autoplay: false, // Load but don't play automatically, as requested "visible but selected"
                };

                // Backup for React hydration race conditions
                window.FONOTECA_PLAYLIST = playlistData;

                const event = new CustomEvent("set-playlist", {
                    detail: playlistData,
                });
                window.dispatchEvent(event);
            }
        }

        // Multiple triggers to ensure it catches the player
        if (
            document.readyState === "interactive" ||
            document.readyState === "complete"
        ) {
            initPlaylist();
        } else {
            document.addEventListener("DOMContentLoaded", initPlaylist);
        }

        // Support for View Transitions
        document.addEventListener("astro:page-load", initPlaylist);
    </script>
</Layout>
