---
import Layout from "../../../layouts/Layout.astro";
import { Header } from "../../../components/react/Header";
import { Footer } from "../../../components/react/Footer";
import { PageBanner } from "../../../components/react/PageBanner";
import { SpeciesGallery } from "../../../components/react/SpeciesGallery";
import { AudioPlayer } from "../../../components/react/AudioPlayer";
import { translations, LANGUAGES, type Language } from "../../../i18n/data";
import { getAllSpecies, type Species } from "../../../data/species";
import logoIiap from "../../../assets/logo_iiap.png";

export async function getStaticPaths() {
    const speciesList = await getAllSpecies();

    return LANGUAGES.flatMap((lang) =>
        speciesList.map((species) => ({
            params: { lang, id: species.id },
            props: { species },
        })),
    );
}

const { lang } = Astro.params;
const { species } = Astro.props as { species: Species };
const content = translations[lang as keyof typeof translations];
const currentLang = lang as Language;

if (!species) {
    return Astro.redirect(`/${lang}/species`);
}

// Localized data
const commonName = species[
    `commonName_${currentLang}` as keyof Species
] as string;
const description =
    species.description[currentLang as keyof typeof species.description];
const characteristics = species.characteristics
    ? species.characteristics[
          currentLang as keyof typeof species.characteristics
      ]
    : undefined;

const galleryImages =
    species.galleryImages.length > 0
        ? species.galleryImages
        : [species.mainImage];
---

<Layout
    title={`${commonName} - ${content.nav.library}`}
    lang={lang}
    description={`Escucha el sonido de: ${commonName} (${species.scientificName})`}
    image={species.mainImage}
>
    <Header
        client:load
        content={content.nav}
        logoSrc={logoIiap.src}
        lang={lang}
    />
    <main>
        <PageBanner
            title={commonName}
            subtitle={species.scientificName}
            image={species.mainImage}
        />

        <section class="py-24 bg-white">
            <div class="container mx-auto px-6">
                {/* Back Link */}
                <div class="mb-12">
                    <a
                        href={`/${lang}/species`}
                        class="inline-flex items-center text-accent-green hover:underline font-medium"
                    >
                        &larr; {
                            lang === "es"
                                ? "Volver a la lista"
                                : lang === "pt"
                                  ? "Voltar para lista"
                                  : "Back to list"
                        }
                    </a>
                </div>

                <div class="max-w-5xl mx-auto">
                    {/* Header Section: Titles & Location */}
                    <div class="text-center mb-12">
                        <h1
                            class="text-4xl md:text-6xl text-primary-dark font-light mb-4"
                        >
                            {commonName}
                        </h1>
                        <h2
                            class="text-2xl md:text-3xl text-accent-green font-serif italic mb-6"
                        >
                            {species.scientificName}
                        </h2>

                        <div
                            class="inline-flex items-center gap-3 text-gray-500 bg-gray-50 px-6 py-3 rounded-full border border-gray-100"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                class="w-5 h-5 text-accent-green"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"
                                ></path>
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
                                ></path>
                            </svg>
                            <span class="font-medium">{species.location}</span>
                        </div>
                    </div>

                    {/* Gallery Section - Centered */}
                    <div class="mb-16">
                        <SpeciesGallery client:load images={galleryImages} />
                    </div>

                    {/* Audio Section - Prominent */}
                    <div class="mb-16">
                        <h3
                            class="text-2xl font-bold text-primary-dark mb-6 text-center"
                        >
                            {
                                lang === "es"
                                    ? "Audios y Espectrogramas"
                                    : lang === "pt"
                                      ? "Áudios e Espectrogramas"
                                      : "Audios & Spectrograms"
                            }
                        </h3>
                        <div class="space-y-8">
                            {
                                species.audios.map((audio) => (
                                    <div class="bg-gray-50 p-8 rounded-3xl border border-gray-100 shadow-sm">
                                        <h4 class="text-xl font-medium text-gray-800 mb-4">
                                            {audio.title}
                                        </h4>
                                        <div class="h-auto">
                                            <AudioPlayer
                                                client:only="react"
                                                audioUrl={audio.url}
                                                title={audio.title}
                                                artist={commonName}
                                                description={audio.description}
                                                spectrogramImage={
                                                    audio.spectrogramImage
                                                }
                                            />
                                        </div>
                                    </div>
                                ))
                            }
                        </div>
                    </div>

                    {/* Info & Characteristics Section */}
                    <div
                        class="grid grid-cols-1 md:grid-cols-3 gap-12 border-t border-gray-100 pt-12"
                    >
                        <div class="md:col-span-2 prose prose-lg text-gray-600">
                            <h3
                                class="text-xl font-bold text-primary-dark mb-4"
                            >
                                {
                                    lang === "es"
                                        ? "Descripción"
                                        : lang === "pt"
                                          ? "Descrição"
                                          : "Description"
                                }
                            </h3>
                            <p>{description}</p>
                        </div>

                        <div>
                            {
                                characteristics &&
                                    characteristics.length > 0 && (
                                        <div>
                                            <h3 class="text-xl font-bold text-primary-dark mb-4">
                                                {lang === "es"
                                                    ? "Características"
                                                    : lang === "pt"
                                                      ? "Características"
                                                      : "Characteristics"}
                                            </h3>
                                            <ul class="space-y-3 text-gray-600">
                                                {characteristics.map((char) => (
                                                    <li class="flex items-start gap-2">
                                                        <span class="text-accent-green mt-1">
                                                            •
                                                        </span>
                                                        {char}
                                                    </li>
                                                ))}
                                            </ul>
                                        </div>
                                    )
                            }

                            <div class="mt-8">
                                <button
                                    class="w-full px-6 py-3 rounded-xl border border-gray-200 text-gray-600 hover:border-accent-green hover:text-accent-green transition-colors font-medium flex items-center justify-center gap-2 bg-white shadow-sm hover:shadow-md"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke-width="1.5"
                                        stroke="currentColor"
                                        class="w-5 h-5"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.935 2.186 2.25 2.25 0 00-3.935-2.186zm0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185z"
                                        ></path>
                                    </svg>
                                    {
                                        lang === "es"
                                            ? "Compartir"
                                            : lang === "pt"
                                              ? "Compartilhar"
                                              : "Share"
                                    }
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
    <Footer content={content.footer} logoSrc={logoIiap.src} />

    <script define:vars={{ species, commonName }}>
        // Initialize PersistentPlayer with this species' audios
        function initPlaylist() {
            if (species.audios && species.audios.length > 0) {
                const playlist = species.audios.map((audio) => ({
                    title: audio.title,
                    artist: commonName,
                    url: audio.url,
                    image: species.mainImage, // Using main image as fallback, but spectrogram is primary for thumbnail
                    spectrogram: audio.spectrogramImage,
                }));

                const playlistData = {
                    playlist: playlist,
                    startAtIndex: 0,
                    autoplay: false, // Load but don't play automatically, as requested "visible but selected"
                };

                // Backup for React hydration race conditions
                window.FONOTECA_PLAYLIST = playlistData;

                const event = new CustomEvent("set-playlist", {
                    detail: playlistData,
                });
                window.dispatchEvent(event);
            }
        }

        // Multiple triggers to ensure it catches the player
        if (
            document.readyState === "interactive" ||
            document.readyState === "complete"
        ) {
            initPlaylist();
        } else {
            document.addEventListener("DOMContentLoaded", initPlaylist);
        }

        // Support for View Transitions
        document.addEventListener("astro:page-load", initPlaylist);
    </script>
</Layout>
