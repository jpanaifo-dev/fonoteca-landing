---
import Layout from "../../../layouts/Layout.astro";
import { Header } from "../../../components/react/Header";
import { Footer } from "../../../components/react/Footer";
import { PageBanner } from "../../../components/react/PageBanner";
import { translations, LANGUAGES } from "../../../i18n/data";
import logoIiap from "../../../assets/logo_iiap.png";

export function getStaticPaths() {
    const paths = [];

    // Generate paths for all species in all languages
    // NOTE: Ideally we iterate over a master list of IDs, here we just use what's in 'es' as source of truth for IDs
    const masterList = translations.es.species_page.list;

    LANGUAGES.forEach((lang) => {
        masterList.forEach((species) => {
            paths.push({ params: { lang, id: species.id } });
        });
    });

    return paths;
}

const { lang, id } = Astro.params;
const content = translations[lang as keyof typeof translations];
const speciesList = content.species_page.list;
const species = speciesList.find((s) => s.id === id);

if (!species) {
    return Astro.redirect(`/${lang}/species`);
}
---

<Layout
    title={`${species.name} - ${content.nav.library}`}
    lang={lang}
    description={`Escucha el sonido de: ${species.name} (${species.scientific})`}
>
    <Header client:load content={content.nav} logoSrc={logoIiap.src} />
    <main>
        <PageBanner
            title={species.name}
            subtitle={species.scientific}
            image={species.image}
        />

        <section class="py-24 bg-white">
            <div class="container mx-auto px-6 text-center">
                <h2 class="text-3xl font-light text-primary-dark mb-8">
                    Detalle de Especie
                </h2>
                <p class="text-xl text-gray-500 mb-12">
                    Funcionalidad de detalle en desarrollo. <br />
                    Aquí se mostrará el reproductor de audio, espectrograma y mapa
                    de distribución.
                </p>
                <a
                    href={`/${lang}/species`}
                    class="inline-flex items-center text-accent-green hover:underline"
                >
                    &larr; Volver a la lista
                </a>
            </div>
        </section>
    </main>
    <Footer content={content.footer} logoSrc={logoIiap.src} />
</Layout>
